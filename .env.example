# Shared knowledge fallback. Project docs now live in each repo at .openclaw/knowledge by default.
OPENCLAW_KNOWLEDGE_PATH=./knowledge
OPENCLAW_SHARED_KNOWLEDGE_PATH=
OPENCLAW_CONTEXT_PATH=./.openclaw/context
SQLITE_PATH=./data/openclaw.db

# Automation / n8n
OPENCLAW_AUTOMATION_TOKEN=change-me
MISSION_CONTROL_BASE_URL=http://localhost:3000
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook
N8N_API_KEY=

# CodeGraph narrow production flags (safe defaults)
MISSION_CONTROL_CODEGRAPH_BOUNDED_MODE=true
MISSION_CONTROL_CODEGRAPH_STRICT_GATE_MODE=true
MISSION_CONTROL_CODEGRAPH_FALLBACK_MODE=true
MISSION_CONTROL_CODEGRAPH_DIAGNOSTICS_MODE=false
MISSION_CONTROL_CODEGRAPH_TOKEN_DELTA_BUDGET=225
MISSION_CONTROL_CODEGRAPH_INDEX_RETRIES=2
MISSION_CONTROL_CODEGRAPH_STALE_CACHE_TTL_MINUTES=180

# CodeGraph runtime/index controls
# refresh = task-time light refresh (safe default), full = explicit/scheduled full indexing
MISSION_CONTROL_CODEGRAPH_INDEX_MODE=refresh
# Hard timeout (ms) for index operations before fallback behavior kicks in
MISSION_CONTROL_CODEGRAPH_INDEX_TIMEOUT_MS=120000
# Base retry backoff (ms), exponential per retry attempt
MISSION_CONTROL_CODEGRAPH_RETRY_BACKOFF_MS=1200

# Agent eval guardrails (Promptfoo)
MISSION_CONTROL_EVAL_MIN_SCORE=0.8
MISSION_CONTROL_EVAL_MAX_COST_USD=0.50
MISSION_CONTROL_EVAL_MAX_FAILURE_RATE=0.15
MISSION_CONTROL_EVAL_DEGRADED_SCORE_MARGIN=0.05
MISSION_CONTROL_EVAL_DEGRADED_COST_USD_MARGIN=0.10
MISSION_CONTROL_EVAL_DEGRADED_FAILURE_RATE_MARGIN=0.05
MISSION_CONTROL_EVAL_REGRESSION_HISTORY_LIMIT=10
MISSION_CONTROL_EVAL_REGRESSION_WINDOW_SIZE=3
MISSION_CONTROL_EVAL_REGRESSION_SCORE_DROP_TOLERANCE=0.03
MISSION_CONTROL_EVAL_REGRESSION_FAILURE_RISE_TOLERANCE=0.03

# OpenClaw runtime reliability
MISSION_CONTROL_OPENCLAW_MAX_ATTEMPTS=3
MISSION_CONTROL_OPENCLAW_HARD_TIMEOUT_BUDGET_MS=240000
MISSION_CONTROL_OPENCLAW_ATTEMPT_TIMEOUT_MS=90000
MISSION_CONTROL_OPENCLAW_BACKOFF_BASE_MS=750
MISSION_CONTROL_TELEGRAM_MESSAGE_LIMIT=4096
MISSION_CONTROL_RELIABILITY_RUN_LIMIT=20
MISSION_CONTROL_RELIABILITY_MIN_SAMPLES=20
MISSION_CONTROL_RELIABILITY_MAX_TIMEOUT_RATE=0.20
MISSION_CONTROL_RELIABILITY_MAX_FAILOVER_RATE=0.50
MISSION_CONTROL_RELIABILITY_MAX_TOOL_ERROR_RATE=0.10
MISSION_CONTROL_RELIABILITY_MAX_AVG_DURATION_MS=120000
MISSION_CONTROL_AUTO_ROUTE_TUNING_ENABLED=1
MISSION_CONTROL_ROUTE_TUNING_MIN_SAMPLE=20
MISSION_CONTROL_ROUTE_TUNING_DEGRADATION_THRESHOLD=0.25
OPENCLAW_MODEL_PRIMARY=default
OPENCLAW_MODEL_FALLBACK=default-fallback

# Tool admission gate (Directive Forge source-pack scoring)
MISSION_CONTROL_TOOL_ADMISSION_REQUIRED_WINS=2
MISSION_CONTROL_TOOL_ADMISSION_MIN_QUALITY_GAIN=0.03
MISSION_CONTROL_TOOL_ADMISSION_MIN_COST_REDUCTION=0.08
MISSION_CONTROL_TOOL_ADMISSION_MIN_FAILURE_REDUCTION=0.10
MISSION_CONTROL_TOOL_ADMISSION_HARD_QUALITY_FLOOR=0.70
MISSION_CONTROL_TOOL_ADMISSION_HARD_FAILURE_CEILING=0.25
MISSION_CONTROL_RELIABILITY_SOFT_MODE=0
