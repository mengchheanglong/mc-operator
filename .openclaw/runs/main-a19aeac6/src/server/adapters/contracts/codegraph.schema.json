{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mission-control/adapter/codegraph-summary",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "required": ["projectRootPath"],
      "properties": {
        "projectRootPath": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "output": {
      "type": "object",
      "properties": {
        "block": { "type": "object" },
        "reason": { "type": "string" },
        "reasonCode": { "type": "string" }
      },
      "anyOf": [{ "required": ["block"] }, { "required": ["reasonCode"] }],
      "additionalProperties": true
    }
  },
  "required": ["input", "output"],
  "additionalProperties": false
}
