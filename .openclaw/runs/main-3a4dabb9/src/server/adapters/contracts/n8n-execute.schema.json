{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mission-control/adapter/n8n-execute",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "required": ["targetUrl", "payload", "idempotencyKey"],
      "properties": {
        "targetUrl": { "type": "string", "minLength": 1 },
        "payload": { "type": "object" },
        "idempotencyKey": { "type": "string", "minLength": 1 },
        "timeoutMs": { "type": "number", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "output": {
      "type": "object",
      "required": ["ok", "status", "body"],
      "properties": {
        "ok": { "type": "boolean" },
        "status": { "type": "number" },
        "body": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "required": ["input", "output"],
  "additionalProperties": false
}
