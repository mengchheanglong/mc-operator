{
  "name": "mc-operator",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "node ./scripts/dev/run-stack.mjs",
    "dev:web": "next dev --webpack",
    "dev:stack": "node ./scripts/dev/run-stack.mjs",
    "dev:turbo": "next dev",
    "backend:dev": "npm --prefix ./backend run dev",
    "backend:build": "npm --prefix ./backend run build",
    "backend:start": "npm --prefix ./backend run start",
    "clean:next": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true});console.log('Removed .next cache')}catch(e){console.log('No .next cache to remove')}\"",
    "dev:reset": "npm run clean:next && next dev --webpack",
    "build": "next build --webpack && node ./scripts/prepare-standalone.mjs",
    "build:webpack": "next build --webpack && node ./scripts/prepare-standalone.mjs",
    "build:turbo": "next build && node ./scripts/prepare-standalone.mjs",
    "start": "node ./.next/standalone/server.js",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json --incremental false",
    "verify": "npm run lint && npm run typecheck && npm run build",
    "verify:product": "npm run test && npm run typecheck && node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/check-backend-api-suite.ts && npm run ui:smoke && npm run check:ui-smoke",
    "check:directive-forge-boundary-inventory": "tsx ./scripts/directive/checks/forge-boundary-inventory.ts",
    "check:directive-forge-sync": "tsx ./scripts/directive/checks/forge-sync.ts",
    "check:directive-workspace-health": "tsx ./scripts/directive/checks/workspace-health.ts",
    "check:directive-workflow-doctrine": "tsx ./scripts/check-directive-workflow-doctrine.ts",
    "check:directive-engine": "tsx ./scripts/directive/checks/engine.ts",
    "check:directive-standalone-surface": "tsx ./scripts/directive/checks/standalone-surface.ts",
    "check:directive-standalone-host": "tsx ./scripts/check-directive-standalone-host.ts",
    "check:directive-standalone-bootstrap": "tsx ./scripts/check-directive-standalone-bootstrap.ts",
    "check:directive-standalone-api-host": "tsx ./scripts/check-directive-standalone-api-host.ts",
    "check:directive-standalone-api-auth": "tsx ./scripts/check-directive-standalone-api-auth.ts",
    "check:directive-standalone-runtime-profile": "tsx ./scripts/check-directive-standalone-runtime-profile.ts",
    "check:directive-standalone-sqlite-persistence": "tsx ./scripts/check-directive-standalone-sqlite-persistence.ts",
    "check:directive-standalone-forge-host": "tsx ./scripts/check-directive-standalone-forge-host.ts",
    "check:directive-frontend-host-compat": "tsx ./scripts/directive/checks/frontend-host-compat.ts",
    "check:directive-host-integration-boundary": "tsx ./scripts/directive/checks/host-integration-boundary.ts",
    "check:directive-host-integration-kit": "tsx ./scripts/directive/checks/host-integration-kit.ts",
    "check:directive-shared-lib-sync": "tsx ./scripts/directive/checks/shared-lib-sync.ts",
    "check:directive-holding-contracts": "tsx ./scripts/check-directive-holding-contracts.ts",
    "check:directive-forge-records": "tsx ./scripts/directive/checks/forge-records.ts",
    "check:directive-architecture-source-storage": "tsx ./scripts/check-directive-architecture-source-storage.ts",
    "check:directive-source-pack-hygiene": "tsx ./scripts/directive/checks/source-pack-hygiene.ts",
    "check:directive-promotion-profile-catalog": "tsx ./scripts/directive/checks/promotion-profile-catalog.ts",
    "check:directive-agent-orchestrator-host-scope": "tsx ./scripts/check-directive-agent-orchestrator-host-scope.ts",
    "check:discovery-monitor-review-cadence": "tsx ./scripts/check-discovery-monitor-review-cadence.ts",
    "check:discovery-deferred-triggers": "tsx ./scripts/check-discovery-deferred-triggers.ts",
    "check:discovery-intake-queue": "tsx ./scripts/check-discovery-intake-queue.ts",
    "check:discovery-intake-transition": "tsx ./scripts/check-discovery-intake-transition.ts",
    "check:discovery-intake-lifecycle-sync": "tsx ./scripts/check-discovery-intake-lifecycle-sync.ts",
    "check:discovery-case-record-writer": "tsx ./scripts/check-discovery-case-record-writer.ts",
    "check:directive-transformation-proof": "tsx ./scripts/check-directive-transformation-proof.ts",
    "check:directive-architecture-schemas": "tsx ./scripts/check-directive-architecture-schemas.ts",
    "check:directive-promotion-quality-contracts": "tsx ./scripts/check-directive-promotion-quality-contracts.ts",
    "check:directive-architecture-wave-evaluation": "tsx ./scripts/check-directive-architecture-wave-evaluation.ts",
    "check:backend-api-suite": "node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/check-backend-api-suite.ts",
    "directive:seed:candidates": "tsx ./scripts/seed-directive-workspace-candidates.ts",
    "directive:lifecycle": "tsx ./scripts/run-directive-candidate-lifecycle.ts",
    "check:codegraph-rollback": "node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/check-codegraph-rollback-threshold.ts",
    "eval:agents": "node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/run-agent-evals.ts",
    "check:agent-evals": "node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/check-agent-evals.ts",
    "check:nightly-hotspot-summary-health": "tsx ./scripts/check-nightly-hotspot-summary-health.ts",
    "check:nightly-summary-health": "tsx ./scripts/check-nightly-summary-health.ts",
    "check:ops-health": "tsx ./scripts/check-ops-health.ts",
    "check:workspace-health-nightly": "tsx ./scripts/check-workspace-health-nightly.ts",
    "ops:nightly:summary": "tsx ./scripts/render-nightly-ops-summary.ts",
    "ops:report:prune": "tsx ./scripts/run-ops-report-prune.ts",
    "check:contract-freeze": "tsx ./scripts/check-contract-freeze.ts",
    "ops:repo-sources:seed": "tsx ./scripts/repo-sources/seed.ts",
    "ops:repo-sources:check": "tsx ./scripts/repo-sources/check.ts",
    "ops:repo-sources:update": "tsx ./scripts/repo-sources/update.ts",
    "check:canary-health": "tsx ./scripts/check-canary-health.ts",
    "ui:smoke": "node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/ui/run-smoke.ts",
    "check:ui-smoke": "node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/ui/check-smoke.ts",
    "test": "node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test ./tests/current/*.test.ts",
    "spike:codegraph": "node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/run-codegraph-spike.ts mc-operator",
    "spike:codegraph:summary": "node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/summarize-codegraph-telemetry.ts 20",
    "audit:all": "npm audit",
    "audit:prod": "npm audit --omit=dev",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test:workflow-memory-injection": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-workflow-memory-injection.ps1"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-table": "^8.21.3",
    "@xyflow/react": "^12.10.1",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.6.2",
    "canvas-confetti": "^1.9.0",
    "d3-force": "^3.0.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.37",
    "lucide-react": "^0.300.0",
    "next": "^16.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^25.3.5",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.8",
    "promptfoo": "^0.121.2",
    "puppeteer": "^24.39.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
